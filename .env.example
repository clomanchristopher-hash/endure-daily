# Supabase — copy this file to `.env.local` and fill in your project's values.
# Find them in the Supabase dashboard: Project Settings → API.
# The app runs fine WITHOUT these (offline mode, localStorage only); set them
# to enable accounts and cross-device sync.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
